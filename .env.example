# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env.local and populate with actual values for local development
# Never commit .env.local or any file containing real secrets to version control

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =============================================================================
# Database (Supabase PostgreSQL)
# =============================================================================
# Connection string for Drizzle ORM (pooled connection)
DATABASE_URL=postgresql://user:password@host:5432/database

# Direct connection string (non-pooled, for migrations)
DIRECT_URL=postgresql://user:password@host:5432/database

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, safe for client-side)
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Storage (Cloudflare R2)
# =============================================================================
# Cloudflare account ID
R2_ACCOUNT_ID=your-account-id

# R2 access credentials
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# R2 bucket name
R2_BUCKET_NAME=your-bucket-name

# Public URL for R2 bucket (custom domain or R2.dev URL)
R2_PUBLIC_URL=https://your-bucket.r2.dev

# =============================================================================
# Authentication (Google OAuth)
# =============================================================================
# Google OAuth client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI (must match Google Console configuration)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# =============================================================================
# better-auth Configuration
# =============================================================================
# Secret key for signing tokens (min 32 characters, generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-min-32-characters

# Base URL for auth callbacks
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# Enable Vercel Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable debug mode
NEXT_PUBLIC_ENABLE_DEBUG=true
