# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env.local and populate with actual values for local development
# Never commit .env.local or any file containing real secrets to version control

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =============================================================================
# Database (Supabase PostgreSQL)
# =============================================================================
# Connection string for Drizzle ORM (pooled connection)
DATABASE_URL=postgresql://user:password@host:5432/database

# Direct connection string (non-pooled, for migrations)
DIRECT_URL=postgresql://user:password@host:5432/database

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, safe for client-side)
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Storage (S3-compatible - MinIO local / Cloudflare R2 production)
# =============================================================================
# Shared connection settings (applies to both buckets)
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin

# Attachments bucket (issue attachments - requires auth via presigned URLs)
STORAGE_ATTACHMENTS_BUCKET=ui-syncup-attachments
STORAGE_ATTACHMENTS_PUBLIC_URL=http://127.0.0.1:9000/ui-syncup-attachments

# Media bucket (avatars, team logos - public read)
STORAGE_MEDIA_BUCKET=ui-syncup-media
STORAGE_MEDIA_PUBLIC_URL=http://127.0.0.1:9000/ui-syncup-media


# =============================================================================
# Authentication (Google OAuth)
# =============================================================================
# Google OAuth client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI (must match Google Console configuration)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# =============================================================================
# better-auth Configuration
# =============================================================================
# Secret key for signing tokens and session cookies (REQUIRED, min 32 characters)
# Generate with: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: Keep this secret secure and never commit to version control
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-replace-this-value

# Base URL for auth callbacks (must match your deployment URL)
# Local: http://localhost:3000
# Production: https://your-domain.com
# Preview: https://dev.your-domain.com
#
# ⚠️ CRITICAL FOR VERCEL DEPLOYMENTS ⚠️
# This file is a template only. For Vercel deployments, you MUST configure
# this variable in Vercel Dashboard → Settings → Environment Variables.
# The value in this file will NOT be used by Vercel!
#
# Why? Vercel requires explicit environment variable configuration per environment scope.
# Failure to configure this will result in localhost URLs in verification emails.
#
# See docs/DEPLOYMENT.md for complete setup instructions.
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# Email Service (Resend)
# =============================================================================
# Resend API Key (REQUIRED for email verification and password reset)
# Get your API key from: https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_123456789_replace_with_your_actual_key

# Default sender email address (must be verified in Resend)
# For development: Use a verified domain or resend's test domain
# For production: Use your verified domain (e.g., noreply@your-domain.com)
# Note: Emails from unverified domains will be rejected
RESEND_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# Enable Vercel Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable debug mode
NEXT_PUBLIC_ENABLE_DEBUG=true

# =============================================================================
# Authentication (Microsoft OAuth) 
# =============================================================================
# Register an app at: https://portal.azure.com → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant ID: Use 'common' for multi-tenant + personal accounts, or a specific tenant ID
MICROSOFT_TENANT_ID=common

# =============================================================================
# Authentication (Atlassian OAuth)
# =============================================================================
# Create an OAuth 2.0 app at: https://developer.atlassian.com/console/myapps/
# Callback URL: http://localhost:3000/api/auth/callback/atlassian
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
