# ============================================================================
# UI SyncUp — Production Environment Template
# ============================================================================
# Copy this file to .env in the same directory as docker/compose.yml.
# Fill in every placeholder before running docker compose up -d.
# DO NOT commit this file with real secrets to version control.
# ============================================================================

# ============================================================================
# Docker Compose Profiles
# ============================================================================
# Controls which infrastructure services are bundled.
#
# Options (comma-separated, no spaces):
#   db      → postgres:15-alpine
#   cache   → redis:7-alpine
#   storage → minio + automatic bucket creation
#
# All bundled:    COMPOSE_PROFILES=db,cache,storage
# All external:   COMPOSE_PROFILES=
# On Coolify/Dokploy: set this in the platform's Environment Variables UI.
COMPOSE_PROFILES=

# Host port mapped to the app container (default: 3000)
PORT=3000

# ============================================================================
# Application
# ============================================================================
NODE_ENV=production

NEXT_PUBLIC_APP_URL={{APP_URL}}
NEXT_PUBLIC_API_URL={{APP_URL}}/api

# ============================================================================
# Database
# ============================================================================
# Pooled connection for Drizzle ORM
DATABASE_URL={{DATABASE_URL}}

# Non-pooled direct connection — used exclusively by db:migrate on startup
DIRECT_URL={{DIRECT_URL}}

# --- Bundled Postgres (add 'db' to COMPOSE_PROFILES) ---
# When using bundled Postgres, set DATABASE_URL and DIRECT_URL to:
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
#
# POSTGRES_USER=syncup
# POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}
# POSTGRES_DB=ui_syncup

# ============================================================================
# Cache
# ============================================================================
# Bundled Redis (add 'cache' to COMPOSE_PROFILES): REDIS_URL=redis://redis:6379
# External (Upstash, Redis Cloud, etc.):           REDIS_URL=rediss://...
REDIS_URL={{REDIS_URL}}

# ============================================================================
# Storage (S3-compatible)
# ============================================================================
#
# Choose ONE of the three options below and fill in the relevant values.
# Delete or comment out the options you are not using.
#
# ── Option A: AWS S3 or Lightsail object storage ─────────────────────────────
# Leave STORAGE_ENDPOINT empty — the AWS SDK resolves the endpoint from the
# region automatically.  Setting it to an AWS URL is NOT needed and breaks
# presigned URL generation.
# Lightsail buckets each have their own access key (use per-bucket vars below).
#
STORAGE_ENDPOINT=
STORAGE_REGION={{STORAGE_REGION}}         # e.g. ap-southeast-1

# Option A — shared credentials (single IAM user / role for both buckets):
# STORAGE_ACCESS_KEY_ID={{STORAGE_ACCESS_KEY_ID}}
# STORAGE_SECRET_ACCESS_KEY={{STORAGE_SECRET_ACCESS_KEY}}

# Option A — per-bucket credentials (Lightsail: each bucket has its own key):
STORAGE_ATTACHMENTS_ACCESS_KEY_ID={{STORAGE_ATTACHMENTS_ACCESS_KEY_ID}}
STORAGE_ATTACHMENTS_SECRET_ACCESS_KEY={{STORAGE_ATTACHMENTS_SECRET_ACCESS_KEY}}
STORAGE_MEDIA_ACCESS_KEY_ID={{STORAGE_MEDIA_ACCESS_KEY_ID}}
STORAGE_MEDIA_SECRET_ACCESS_KEY={{STORAGE_MEDIA_SECRET_ACCESS_KEY}}

STORAGE_ATTACHMENTS_BUCKET={{STORAGE_ATTACHMENTS_BUCKET}}
STORAGE_ATTACHMENTS_PUBLIC_URL=https://{{STORAGE_ATTACHMENTS_BUCKET}}.s3.{{STORAGE_REGION}}.amazonaws.com

STORAGE_MEDIA_BUCKET={{STORAGE_MEDIA_BUCKET}}
STORAGE_MEDIA_PUBLIC_URL=https://{{STORAGE_MEDIA_BUCKET}}.s3.{{STORAGE_REGION}}.amazonaws.com

#
# ── Option B: Cloudflare R2 ───────────────────────────────────────────────────
#
# STORAGE_ENDPOINT=https://{{CF_ACCOUNT_ID}}.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID={{R2_ACCESS_KEY_ID}}
# STORAGE_SECRET_ACCESS_KEY={{R2_SECRET_ACCESS_KEY}}
#
# STORAGE_ATTACHMENTS_BUCKET={{STORAGE_ATTACHMENTS_BUCKET}}
# STORAGE_ATTACHMENTS_PUBLIC_URL=https://{{R2_ATTACHMENTS_PUBLIC_DOMAIN}}  # custom domain / pub URL
#
# STORAGE_MEDIA_BUCKET={{STORAGE_MEDIA_BUCKET}}
# STORAGE_MEDIA_PUBLIC_URL=https://{{R2_MEDIA_PUBLIC_DOMAIN}}  # custom domain / pub URL
#
# ── Option C: Bundled MinIO (add 'storage' to COMPOSE_PROFILES) ──────────────
#
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID={{STORAGE_ACCESS_KEY_ID}}
# STORAGE_SECRET_ACCESS_KEY={{STORAGE_SECRET_ACCESS_KEY}}
# MINIO_ROOT_USER={{STORAGE_ACCESS_KEY_ID}}
# MINIO_ROOT_PASSWORD={{STORAGE_SECRET_ACCESS_KEY}}
#
# STORAGE_ATTACHMENTS_BUCKET=ui-syncup-attachments
# STORAGE_ATTACHMENTS_PUBLIC_URL=http://{{YOUR_HOST}}:9000/ui-syncup-attachments
#
# STORAGE_MEDIA_BUCKET=ui-syncup-media
# STORAGE_MEDIA_PUBLIC_URL=http://{{YOUR_HOST}}:9000/ui-syncup-media

# ============================================================================
# Authentication (better-auth)
# ============================================================================
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET={{BETTER_AUTH_SECRET}}
BETTER_AUTH_URL={{APP_URL}}

# ============================================================================
# Email Service — configure ONE option
# ============================================================================

# Option A: Resend (cloud)
# RESEND_API_KEY={{RESEND_API_KEY}}
# RESEND_FROM_EMAIL={{RESEND_FROM_EMAIL}}

# Option B: SMTP (self-hosted — Mailcow, Postfix, AWS SES, etc.)
# When SMTP_HOST is set, all fields below are required.
# SMTP_HOST={{SMTP_HOST}}
# SMTP_PORT=587
# SMTP_USER={{SMTP_USER}}
# SMTP_PASSWORD={{SMTP_PASSWORD}}
# SMTP_FROM_EMAIL={{SMTP_FROM_EMAIL}}
# SMTP_SECURE=false

# ============================================================================
# Authentication — OAuth Providers (all optional)
# ============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI={{APP_URL}}/api/auth/callback/google

# Microsoft OAuth
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Atlassian OAuth
# ATLASSIAN_CLIENT_ID=
# ATLASSIAN_CLIENT_SECRET=

# ============================================================================
# Feature Flags (optional)
# ============================================================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_DEBUG=false
