# Test Environment Variables
NODE_ENV=test

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database (Test) - Using local Supabase database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase (Test)
SUPABASE_URL=https://test.supabase.co
SUPABASE_ANON_KEY=test-anon-key-for-testing
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key-for-testing

# Storage (Test)
R2_ACCOUNT_ID=test-account-id
R2_ACCESS_KEY_ID=test-access-key-id
R2_SECRET_ACCESS_KEY=test-secret-access-key
R2_BUCKET_NAME=test-bucket
R2_PUBLIC_URL=https://test.r2.dev

# Authentication (Test)
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# better-auth (Test)
BETTER_AUTH_SECRET=test-secret-key-with-at-least-32-characters-for-testing
BETTER_AUTH_URL=http://localhost:3000

# Email (Test)
RESEND_API_KEY=re_test_key_for_testing
RESEND_FROM_EMAIL=test@example.com

# Feature Flags (Test)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true

# Microsoft OAuth (Test)
MICROSOFT_CLIENT_ID=test-microsoft-client-id
MICROSOFT_CLIENT_SECRET=test-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# Atlassian OAuth (Test)
ATLASSIAN_CLIENT_ID=test-atlassian-client-id
ATLASSIAN_CLIENT_SECRET=test-atlassian-client-secret
